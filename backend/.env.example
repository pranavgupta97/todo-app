# ============================================================================
# Local development environment variables.
#
# Copy this file to backend/.env (which is gitignored) and fill in real values.
#
# Loading the variables (pick one):
#
#   • Shell sourcing — auto-export all KEY=VALUE pairs:
#
#       set -a && source backend/.env && set +a
#       cd backend && ./mvnw spring-boot:run
#
#   • IntelliJ — open the Spring Boot run configuration → "Environment
#     variables" → paste the lines (without the comments).
# ============================================================================

# Google OAuth Client credentials.
#
# Provisioned in Google Cloud Console:
#   https://console.cloud.google.com/  →  APIs & Services  →  Credentials
#
# When creating the OAuth client, the authorized redirect URI must be exactly:
#   http://localhost:8080/login/oauth2/code/google
#
# (Production gets its own client ID with a different redirect URI — set up in
# Phase 16 when we deploy.)

GOOGLE_OAUTH_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret-here
